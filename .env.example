# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/task-management 

# JWT
JWT_SECRET=place_your_super_secret_jwt_key_here
JWT_EXPIRES_IN=17d

# Environment
NODE_ENV=development

# Frontend URL (for CORS) -> thats not for backend tasks
FRONTEND_URL=http://localhost:3000